# ── Webhook Server Environment ─────────────────────────────────────────────
# Copy this file to .env and fill in the values

# Server
PORT=5000
NODE_ENV=development
DASHBOARD_URL=http://localhost:3001

# PostgreSQL (pgvector) — uses port 5433 to avoid conflict with main_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/webhook_db
WH_POSTGRES_USER=postgres
WH_POSTGRES_PASSWORD=postgres
WH_POSTGRES_DB=webhook_db

# Redis (BullMQ queue)
REDIS_URL=redis://localhost:6379

# JWT (dashboard auth — separate from main-server JWT)
JWT_ACCESS_SECRET=your-dashboard-access-secret-change-me
JWT_REFRESH_SECRET=your-dashboard-refresh-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Webhook endpoint config
WEBHOOK_ID=wh_user_events
WEBHOOK_NAME=User Events
WEBHOOK_SECRET=your-webhook-hmac-secret-change-me
