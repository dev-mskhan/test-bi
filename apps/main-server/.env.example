# ── Main Server Environment ────────────────────────────────────────────────
# Copy this file to .env and fill in the values

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# PostgreSQL (pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/main_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=main_db

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Webhook Integration
WEBHOOK_SERVER_URL=http://localhost:5000
WEBHOOK_SECRET=your-webhook-hmac-secret-change-me
WEBHOOK_ID=wh_user_events
